# TTVH Cinemas — cấu hình Apache cho SSE
# Tắt gzip cho tất cả file SSE

<FilesMatch "(seat_events|film_events|suat_updates)\.php$">
    SetEnvIf Request_URI "." no-gzip dont-vary
    Header set X-Accel-Buffering "no"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI seat_events no-gzip
    SetEnvIfNoCase Request_URI film_events no-gzip
    SetEnvIfNoCase Request_URI suat_updates no-gzip
</IfModule>
