# TTVH Cinemas — cấu hình Apache cho SSE (Server-Sent Events)
# Đặt file này vào thư mục user/ (cùng chỗ với seat_events.php)

# Tắt gzip compression cho file SSE
# (gzip giữ dữ liệu lại đến khi đủ block mới gửi → SSE không hoạt động)
<FilesMatch "seat_events\.php">
    SetEnvIf Request_URI "seat_events" no-gzip dont-vary
    Header set X-Accel-Buffering "no"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Content-Type "text/event-stream; charset=utf-8"
</FilesMatch>

# Nếu dùng mod_deflate, tắt cho SSE
<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI seat_events no-gzip
</IfModule>